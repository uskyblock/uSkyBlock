msgid "<player> tried to invite you, but you are already in a party.<newline><muted>Use <cmd>/is leave</cmd> to leave your current party.</muted>"
msgstr "<player> ने तुम्हें निमंत्रण देने की कोशिश की, लेकिन तुम पहले से ही एक दल में हो।<newline><muted>अपना वर्तमान दल छोड़ने के लिए <cmd>/is leave</cmd> का उपयोग करो।</muted>"

