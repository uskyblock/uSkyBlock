msgstr "<player> کا جزیرہ ہٹایا جا رہا ہے۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/WGCommand.java
msgid "Resending chunks to the client."
msgstr "کلائنٹ کو چنکس دوبارہ بھیجے جا رہے ہیں۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/CooldownCommand.java
msgid "Reset cooldown on <command> for <player> to <seconds> seconds."
msgstr "<player> کے لیے <command> پر کول ڈاؤن کو <seconds> سیکنڈ پر ری سیٹ کر دیا گیا ہے۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminIslandCommand.java
msgid "Set <leader>'s island to be ignored on top-ten and purge."
msgstr "<leader> کے جزیرہ کو top-ten اور purge میں نظرانداز کرنے کے لیے سیٹ کر دیا گیا ہے۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/RegisterIslandToPlayerCommand.java
msgid "Set <player>'s island to the current island."
msgstr "<player> کے جزیرہ کو موجودہ جزیرہ پر سیٹ کر دیا گیا ہے۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/LanguageCommand.java
msgid "Set language with <cmd>/usb lang [locale]</cmd>."
msgstr "<cmd>/usb lang [locale]</cmd> سے زبان سیٹ کریں۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/ProtectAllCommand.java
