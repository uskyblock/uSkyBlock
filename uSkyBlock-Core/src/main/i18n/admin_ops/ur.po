msgstr "<level> لیول سے نیچے اور <days> دن سے زیادہ ترک شدہ تمام جزیرے تلاش کیے جا رہے ہیں۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/GenTopTenCommand.java
msgid "Finished generating the top ten list."
msgstr "ٹاپ ٹین لسٹ بنانا مکمل ہو گیا۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/GenTopTenCommand.java
msgid "Generating the top ten list."
msgstr "ٹاپ ٹین لسٹ بنائی جا رہی ہے۔"

