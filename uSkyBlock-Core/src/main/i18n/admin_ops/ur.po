msgstr "protect-all ٹاسک شروع کیا جا رہا ہے۔ اس میں کچھ وقت لگ سکتا ہے۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/PurgeCommand.java
msgid "Starting purge..."
msgstr "purge شروع کیا جا رہا ہے..."

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/RegionCommand.java
msgid "Stopped displaying regions."
msgstr "ریجنز دکھانا بند کر دیا گیا۔"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/ChunkCommand.java
