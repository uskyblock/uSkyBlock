msgid "Challenge <challenge-id> has already been completed"
msgstr "चुनौती <challenge-id> पहले से पूरी हो चुकी है"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminChallengeCommand.java
msgid "Challenge <challenge-id> has been completed for <player>."
msgstr "<player> के लिए चुनौती <challenge-id> पूरी कर दी गई है।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminChallengeCommand.java
msgid "Challenge <challenge-id> has been reset for <player>."
msgstr "<player> के लिए चुनौती <challenge-id> रीसेट कर दी गई है।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminIslandCommand.java
msgid "Changed <player>'s biome to <biome>."
msgstr "<player> का बायोम <biome> में बदल दिया।"

