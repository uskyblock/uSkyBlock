msgstr "<player> का द्वीप वर्तमान द्वीप पर सेट किया।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/LanguageCommand.java
msgid "Set language with <cmd>/usb lang [locale]</cmd>."
msgstr "<cmd>/usb lang [locale]</cmd> से भाषा सेट करें।"

