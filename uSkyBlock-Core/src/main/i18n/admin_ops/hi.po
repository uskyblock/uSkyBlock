msgid "Finding all islands abandoned for more than <days> days below level <level>."
msgstr "<level> स्तर से नीचे, <days> दिनों से अधिक समय से परित्यक्त सभी द्वीप खोजे जा रहे हैं।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/GenTopTenCommand.java
msgid "Finished generating the top ten list."
msgstr "टॉप-टेन सूची बनाना पूरा हुआ।"

