#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/ProtectAllCommand.java
msgid "- Protect-All <progress_pct:'0%'> (<progress>/<total>, failed:<failed>, skipped:<skipped>) ~ <elapsed>"
msgstr "- Protect-All <progress_pct:'0%'> (<progress>/<total>, विफल:<failed>, छोड़े गए:<skipped>) ~ <elapsed>"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/OrphanCommand.java
msgid "<count> old island locations will be used before new ones."
msgstr "नई लोकेशन से पहले <count> पुरानी द्वीप लोकेशन इस्तेमाल की जाएँगी।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminIslandCommand.java
msgid "<leader>'s island at <island> has been protected."
msgstr "<island> पर <leader> के द्वीप को सुरक्षित कर दिया गया है।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminIslandCommand.java
msgid "<leader>'s island at <island> was already protected"
msgstr "<island> पर <leader> का द्वीप पहले से ही सुरक्षित था"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminChallengeCommand.java
msgid "<player> has had all challenges reset."
msgstr "<player> की सभी चुनौतियाँ रीसेट कर दी गई हैं।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/AdminIslandCommand.java
msgid "<player> has joined your island group."
msgstr "<player> तुम्हारे द्वीप समूह में शामिल हो गया है।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/ProtectAllCommand.java
msgid "A protect-all task is already running. <muted>Let it complete first, or use <cmd>/usb protectall stop</cmd>."
msgstr "Protect-all कार्य पहले से चल रहा है। <muted>पहले इसे पूरा होने दो, या <cmd>/usb protectall stop</cmd> इस्तेमाल करो।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/PurgeCommand.java
msgid "A purge is already running. <muted>Either <primary>confirm</primary> or <primary>stop</primary> it."
msgstr "Purge पहले से चल रहा है। <muted>या तो इसे <primary>confirm</primary> करो या <primary>stop</primary> करो।"

#: uSkyBlock-Core/src/main/java/us/talabrek/ultimateskyblock/command/admin/RegionCommand.java
msgid "Animation tick changed to <ticks>."
msgstr "एनीमेशन टिक को <ticks> पर बदल दिया गया।"

