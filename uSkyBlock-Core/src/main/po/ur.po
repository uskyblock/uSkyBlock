#, java-format
msgid ""
"§e{0}§e tried to invite you, but you are already in a party.To leave your "
"current party, use: /island leave."
msgstr ""
"§e§e{0} نے آپ کو مدعو کرنے کی کوشش کی، لیکن آپ پہلے ہی ایک پارٹی میں ہیں۔ "
"اپنی موجودہ پارٹی چھوڑنے کے لیے استعمال کریں: /island leave."

msgid "§e§lClick here to activate."
msgstr "§e§lفعال کرنے کے لیے یہاں کلک کریں۔"

msgid "§e§lClick here to change biomes."
msgstr "§e§lبایومز تبدیل کرنے کے لیے یہاں کلک کریں۔"

msgid "§e§lClick here to change."
msgstr "§e§lتبدیل کرنے کے لیے یہاں کلک کریں۔"

msgid "§e§lClick here to deactivate."
msgstr "§e§lغیر فعال کرنے کے لیے یہاں کلک کریں۔"

msgid "§e§lClick here to lock your island."
msgstr "§e§lاپنا جزیرہ لاک کرنے کے لیے یہاں کلک کریں۔"

