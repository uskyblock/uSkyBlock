msgstr "§eآپ نے جزیرہ چھوڑ دیا اور کھلاڑی کے اسپان پر واپس آ گئے۔"

msgid "§eYou have rejected the invitation to join an island."
msgstr "§eآپ نے جزیرے میں شامل ہونے کی دعوت رد کر دی ہے۔"

#, java-format
msgid "§eYou have unbanned §a{0}§e from warping to your island."
msgstr "§eآپ نے §a{0}§e کو اپنے جزیرے پر وارپ کرنے سے ان بین کر دیا ہے۔"

msgid "§eYou must be on your island to change the biome!"
msgstr "§eبایوم تبدیل کرنے کے لیے آپ کا اپنے جزیرے پر ہونا ضروری ہے!"

msgid "§eYou must be on your island to use this command."
msgstr "§eیہ کمانڈ استعمال کرنے کے لیے آپ کا اپنے جزیرے پر ہونا ضروری ہے۔"

msgid ""
"§eYou must remove all players from your island before you can restart it (/"
"island kick <player>). See a list of players currently part of your island "
"using /island party."
msgstr ""
"§eجزیرہ ری اسٹارٹ کرنے سے پہلے آپ کو تمام کھلاڑی اپنے جزیرے سے نکالنے ہوں گے "
"(/island kick <player>)۔ اس وقت آپ کے جزیرے کا حصہ بننے والے کھلاڑیوں کی "
"فہرست /island party سے دیکھیں۔"

msgid "§eYou own this island, use /island remove <player> instead."
msgstr ""
"§eیہ جزیرہ آپ کی ملکیت ہے، اس کے بجائے /island remove <player> استعمال کریں۔"

msgid "§eYour inventory is §4full§e. Items dropped on the ground."
msgstr "§eآپ کی انوینٹری §4بھری ہوئی§e ہے۔ آئٹمز زمین پر گرا دیے گئے۔"

msgid "§eYour inventory must have another empty space!"
msgstr "§eآپ کی انوینٹری میں ایک اور خالی جگہ ہونی چاہیے!"

#. I18N: Message sent when a player locks their island
msgid "§eYour island is now locked. Only your party members may enter."
msgstr "§eآپ کا جزیرہ اب لاک ہے۔ صرف آپ کی پارٹی کے ممبرز داخل ہو سکتے ہیں۔"

msgid ""
"§eYour island is unlocked and anyone may enter, however only you and your "
"party members may build or remove blocks."
msgstr ""
"§eآپ کا جزیرہ اَن لاک ہے اور کوئی بھی داخل ہو سکتا ہے، تاہم صرف آپ اور آپ کی "
"پارٹی کے ممبرز بلاکس بنا یا ہٹا سکتے ہیں۔"

