msgstr "§e§lجزیرہ لاگ"

msgid "§f/island [accept/reject]§e to accept or reject the invite."
msgstr "§f/island [accept/reject]§e دعوت قبول یا رد کرنے کے لیے۔"

msgid "§fComplete most challenges in"
msgstr "§fزیادہ تر چیلنجز مکمل کریں"

msgid "§fSet incoming warp to your current location using §e/island setwarp"
msgstr ""
"§fآنے والے وارپ کو اپنی موجودہ جگہ پر سیٹ کرنے کے لیے §e/island setwarp§f "
